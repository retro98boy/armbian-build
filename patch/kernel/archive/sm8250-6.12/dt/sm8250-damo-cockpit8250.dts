		regulator-boot-on;
	};

	regulator-cam-front-vio1v8 {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&tlmm 60 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&cam_front_vio1v8_en>;
		regulator-name = "cam_front_vio1v8";
