		regulator-boot-on;
	};

	regulator-cam-rear1-vdig1v1 {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&tlmm 109 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&cam_rear1_vdig1v1_en>;
		regulator-name = "cam_rear1_vdig1v1";
		regulator-always-on;
		regulator-boot-on;
	};

	regulator-cam-rear2-vdig1v1 {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&tlmm 130 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&cam_rear2_vdig1v1_en>;
		regulator-name = "cam_rear2_vdig1v1";
		regulator-always-on;
		regulator-boot-on;
	};

	regulator-cam-rear3-vdig1v1 {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&tlmm 131 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&cam_rear3_vdig1v1_en>;
		regulator-name = "cam_rear3_vdig1v1";
		regulator-always-on;
		regulator-boot-on;
	};

	regulator-cam-front-vdig1v1 {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&tlmm 61 GPIO_ACTIVE_HIGH>;
