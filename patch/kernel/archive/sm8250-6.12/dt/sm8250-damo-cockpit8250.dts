	regulator-cam-rear-vdig1v1 {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&tlmm 58 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&cam_rear_vdig1v1_en>;
		regulator-name = "cam_rear_vdig1v1";
