	};

	regulator-cam-front-avdd2v8 {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&tlmm 59 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&cam_front_avdd2v8_en>;
		regulator-name = "cam_front_avdd2v8";
