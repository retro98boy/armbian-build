	};

	regulator-display {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&tlmm 23 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&display_en>;
		regulator-name = "display";
		regulator-always-on;
		regulator-boot-on;
