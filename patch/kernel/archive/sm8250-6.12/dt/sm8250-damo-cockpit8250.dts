		regulator-always-on;
		regulator-boot-on;
	};

	regulator-cam-rear-vio1v8 {
		compatible = "regulator-fixed";
		enable-active-high;
		gpio = <&tlmm 57 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&cam_rear_vio1v8_en>;
		regulator-name = "cam_rear_vio1v8";
